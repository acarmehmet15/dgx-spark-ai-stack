# ═══════════════════════════════════════════════
#  DGX Spark AI Stack - Ortam Değişkenleri
# ═══════════════════════════════════════════════

# ─── LiteLLM Gateway ───
LITELLM_MASTER_KEY=sk-litellm-master-key

# ─── Open WebUI ───
WEBUI_SECRET_KEY=your-webui-secret-key

# ─── API Anahtarları (SDLC Agent'lar için) ───
# Anthropic API (doğrudan kullanım için, CLIProxy varsa gereksiz)
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# OpenAI API (isteğe bağlı)
# OPENAI_API_KEY=sk-xxxxx
# Google AI Studio (fallback model için)
# GOOGLE_API_KEY=xxxxx

# ─── GitHub Entegrasyonu ───
GITHUB_TOKEN=ghp_xxxxx

# ─── Azure DevOps (isteğe bağlı) ───
# ADO_MCP_AUTH_TOKEN=your-ado-pat

# ─── PostgreSQL ───
POSTGRES_DB=sdlc_agents
POSTGRES_USER=sdlc
POSTGRES_PASSWORD=sdlc_secret

# ─── Çalışma Ortamı ───
RUNTIME_ENV=dev

# ─── Grafana ───
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
